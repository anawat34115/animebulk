---
interface Props {
  variant?: 'supplements' | 'equipment' | 'apparel';
}
const { variant = 'supplements' } = Astro.props;

const offers = {
  supplements: {
    label: 'Recommended Supplement',
    title: 'Transparent Labs Protein',
    desc: 'The cleanest protein powder on the market. No fillers, no BS — just what your muscles need.',
    cta: 'Get 10% Off →',
    href: '#', // replace with your affiliate link
    badge: 'AnimeBulk Pick',
    color: 'from-blue-900/30 to-dark-800',
    borderColor: 'border-blue-500/20',
    badgeColor: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  },
  equipment: {
    label: 'Recommended Equipment',
    title: 'Rogue Fitness Pull-Up Bar',
    desc: 'The bar Levi would use. Commercial-grade, fits any doorframe, handles weighted pull-ups easily.',
    cta: 'Shop Now →',
    href: '#',
    badge: 'Top Rated',
    color: 'from-gray-800/50 to-dark-800',
    borderColor: 'border-gray-500/20',
    badgeColor: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
  },
  apparel: {
    label: 'Train in Style',
    title: 'Gymshark Lifting Gear',
    desc: 'Performance apparel built for heavy training. Exclusive discount for AnimeBulk members.',
    cta: 'Get the Discount →',
    href: '#',
    badge: 'Exclusive Deal',
    color: 'from-purple-900/20 to-dark-800',
    borderColor: 'border-purple-500/20',
    badgeColor: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  },
};

const offer = offers[variant];
---

<div class={`my-8 bg-gradient-to-r ${offer.color} border ${offer.borderColor} rounded-xl p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4`}>
  <div class="flex-1">
    <div class="flex items-center gap-2 mb-1">
      <span class={`text-xs font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border ${offer.badgeColor}`}>
        {offer.badge}
      </span>
      <span class="text-gray-500 text-xs">{offer.label}</span>
    </div>
    <h3 class="text-white font-bold text-base mb-0.5">{offer.title}</h3>
    <p class="text-gray-400 text-sm">{offer.desc}</p>
  </div>
  <a
    href={offer.href}
    target="_blank"
    rel="noopener noreferrer sponsored"
    class="flex-shrink-0 bg-white/10 hover:bg-brand-500 border border-white/10 hover:border-brand-500 text-white font-bold text-sm px-5 py-2.5 rounded-lg transition-all duration-200 whitespace-nowrap"
  >
    {offer.cta}
  </a>
</div>
<p class="text-gray-600 text-xs -mt-6 mb-4">Affiliate link — we may earn a commission at no extra cost to you.</p>
