---
const testimonials = [
  {
    quote: "I've tried dozens of fitness programs. AnimeBulk is the first one I actually stuck with for more than 2 weeks.",
    name: "Marcus T.",
    detail: "Lost 12 lbs on the Naruto program",
    avatar: "M",
  },
  {
    quote: "The Goku program is no joke. Week 6 I hit a PR on every lift. The nutrition guide alone is worth the price.",
    name: "Kevin L.",
    detail: "Gained 8 lbs of muscle in 12 weeks",
    avatar: "K",
  },
  {
    quote: "Finally a site that combines my two passions. The Levi workout destroyed me in the best way possible.",
    name: "Priya S.",
    detail: "Attack on Titan fan, 3 months in",
    avatar: "P",
  },
];

const stats = [
  { value: '10,000+', label: 'Anime Athletes' },
  { value: '6', label: 'Character Programs' },
  { value: '4.9★', label: 'Average Rating' },
  { value: '$0', label: 'To Get Started' },
];
---

<!-- Stats Bar -->
<div class="bg-dark-800 border-y border-white/5 py-10">
  <div class="max-w-5xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
    {stats.map(s => (
      <div>
        <div class="text-3xl md:text-4xl font-display text-brand-400 mb-1">{s.value}</div>
        <div class="text-gray-500 text-sm">{s.label}</div>
      </div>
    ))}
  </div>
</div>

<!-- Testimonials -->
<section class="py-20 bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-brand-400 text-sm font-bold uppercase tracking-widest mb-2">Real Results</p>
      <h2 class="text-3xl md:text-4xl font-display tracking-wide text-white">
        What Our <span class="bg-gradient-to-r from-brand-400 to-orange-300 bg-clip-text text-transparent">Athletes Say</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="bg-dark-700 border border-white/5 hover:border-brand-500/30 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-300 hover:-translate-y-1">
          <!-- Stars -->
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-brand-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-gray-300 text-sm leading-relaxed flex-1">"{t.quote}"</p>
          <div class="flex items-center gap-3 pt-2 border-t border-white/5">
            <div class="w-9 h-9 rounded-full bg-brand-500/20 border border-brand-500/30 flex items-center justify-center text-brand-400 font-bold text-sm flex-shrink-0">
              {t.avatar}
            </div>
            <div>
              <div class="text-white font-bold text-sm">{t.name}</div>
              <div class="text-gray-500 text-xs">{t.detail}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
