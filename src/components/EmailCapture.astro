---
interface Props {
  title?: string;
  subtitle?: string;
  compact?: boolean;
  formId?: string;
}

const {
  title = 'Get Free Anime Workout Programs',
  subtitle = 'Join 10,000+ anime fans training smarter. Get new character workouts every week — free.',
  compact = false,
  formId = 'email-capture',
} = Astro.props;

// Set CONVERTKIT_FORM_URL in your .env file to wire up ConvertKit.
// Example: CONVERTKIT_FORM_URL=https://app.convertkit.com/forms/XXXXXXX/subscriptions
// Or set MAILCHIMP_URL for Mailchimp.
// If neither is set, the form shows a success message client-side only.
const formEndpoint = import.meta.env.CONVERTKIT_FORM_URL
  || import.meta.env.MAILCHIMP_URL
  || '';
---

<section id={formId} class={compact ? '' : 'py-16 bg-gradient-to-b from-dark-800 to-dark-900'}>
  <div class={compact ? '' : 'max-w-2xl mx-auto px-4 text-center'}>
    {!compact && (
      <div class="inline-flex items-center gap-2 bg-brand-500/10 border border-brand-500/20 rounded-full px-4 py-1.5 mb-6">
        <span class="text-brand-400 text-sm font-semibold">🔥 Free for Subscribers</span>
      </div>
    )}
    <h2 class={`font-display tracking-wide text-white ${compact ? 'text-2xl mb-2' : 'text-3xl md:text-4xl mb-4'}`}>
      {title}
    </h2>
    <p class={`text-gray-400 ${compact ? 'text-sm mb-4' : 'text-lg mb-8'}`}>
      {subtitle}
    </p>

    <form
      class={`flex flex-col sm:flex-row gap-3 ${compact ? '' : 'max-w-md mx-auto'}`}
      data-form-id={formId}
      data-endpoint={formEndpoint}
    >
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 bg-dark-700 border border-white/10 focus:border-brand-500 rounded-lg px-4 py-3 text-white placeholder-gray-500 outline-none transition-colors text-sm"
      />
      <button
        type="submit"
        class="btn-primary whitespace-nowrap"
        data-default-text="Get Free Programs"
        data-loading-text="Joining..."
      >
        Get Free Programs
      </button>
    </form>

    <p class="text-gray-600 text-xs mt-3">No spam. Unsubscribe anytime.</p>

    <div
      id={`${formId}-success`}
      class="hidden mt-4 p-4 bg-green-500/10 border border-green-500/20 rounded-lg text-green-400 text-sm font-semibold"
    >
      🎉 You're in! Check your inbox for your first free program.
    </div>
    <div
      id={`${formId}-error`}
      class="hidden mt-4 p-4 bg-red-500/10 border border-red-500/20 rounded-lg text-red-400 text-sm"
    >
      Something went wrong. Please try again or email us directly.
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-form-id]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formId = form.dataset.formId!;
      const endpoint = form.dataset.endpoint || '';
      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const successEl = document.getElementById(`${formId}-success`);
      const errorEl = document.getElementById(`${formId}-error`);
      const email = emailInput?.value?.trim();

      if (!email) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = submitBtn.dataset.loadingText || 'Joining...';
      }

      errorEl?.classList.add('hidden');

      if (endpoint) {
        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email_address: email, state: 'active' }),
          });

          if (!res.ok) throw new Error('Submission failed');

          form.style.display = 'none';
          successEl?.classList.remove('hidden');
        } catch {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = submitBtn.dataset.defaultText || 'Get Free Programs';
          }
          errorEl?.classList.remove('hidden');
        }
      } else {
        // No endpoint configured — show success UI (dev/demo mode)
        form.style.display = 'none';
        successEl?.classList.remove('hidden');
      }
    });
  });
</script>
