---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.label,
    ...(crumb.href ? { "item": `https://animebulk.com${crumb.href}` } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg class="w-3 h-3 text-gray-700 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {crumb.href && i < crumbs.length - 1 ? (
          <a href={crumb.href} class="hover:text-brand-400 transition-colors">
            {crumb.label}
          </a>
        ) : (
          <span class={i === crumbs.length - 1 ? 'text-gray-300 font-medium truncate max-w-[200px] sm:max-w-xs' : ''}>
            {crumb.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
