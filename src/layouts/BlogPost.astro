---
import BaseLayout from './BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category: string;
  tags: string[];
  slug?: string;
}

const { title, description, pubDate, updatedDate, heroImage, category, tags, slug } = Astro.props;

const allWorkouts = await getCollection('workouts');
const relatedWorkouts = allWorkouts
  .filter(w => tags.some(t => w.data.tags?.includes(t)))
  .slice(0, 3);

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedFormatted = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "image": heroImage ? `https://animebulk.com${heroImage}` : undefined,
  "author": {
    "@type": "Organization",
    "name": "AnimeBulk",
    "url": "https://animebulk.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AnimeBulk",
    "url": "https://animebulk.com"
  }
};
---

<BaseLayout title={title} description={description} image={heroImage} type="article" schema={schema}>
  <div class="pt-16">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog' },
      { label: title },
    ]} />
    <!-- Hero -->
    {heroImage && (
      <div class="relative h-64 md:h-96 overflow-hidden">
        <img src={heroImage} alt={title} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/50 to-transparent" />
      </div>
    )}

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="badge-anime">{category}</span>
        <time class="text-gray-500 text-sm">{formattedDate}</time>
        {updatedFormatted && (
          <span class="text-gray-600 text-xs">Updated: {updatedFormatted}</span>
        )}
      </div>

      <h1 class="text-3xl md:text-5xl font-display tracking-wide text-white mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl text-gray-400 mb-8 leading-relaxed border-l-4 border-brand-500 pl-4">
        {description}
      </p>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map(tag => (
            <span class="text-xs bg-white/5 border border-white/10 text-gray-400 px-3 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- Content -->
      <div class="prose-dark">
        <slot />
      </div>

      <!-- Email Capture mid-article -->
      <div class="my-12 p-6 bg-dark-700 border border-brand-500/20 rounded-2xl">
        <EmailCapture
          title="Want More Free Workout Programs?"
          subtitle="Get character-inspired training plans delivered to your inbox every week."
          compact={true}
          formId={`email-blog-${slug ?? 'post'}`}
        />
      </div>

      <!-- Related Workouts -->
      {relatedWorkouts.length > 0 && (
        <div class="mt-12 pt-10 border-t border-white/5">
          <h2 class="text-2xl font-display tracking-wide text-white mb-6">
            Related <span class="text-gradient">Workouts</span>
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {relatedWorkouts.map(w => (
              <a
                href={`/workouts/${w.slug}`}
                class="group bg-dark-700 border border-white/5 hover:border-brand-500/40 rounded-xl p-5 transition-all duration-200 hover:-translate-y-0.5"
              >
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-brand-500/10 text-brand-400 border border-brand-500/20">
                    {w.data.difficulty}
                  </span>
                </div>
                <h3 class="text-white font-bold text-sm group-hover:text-brand-400 transition-colors leading-snug mb-1">
                  {w.data.character}
                </h3>
                <p class="text-gray-500 text-xs">{w.data.anime} · {w.data.duration}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Back link -->
      <div class="mt-10">
        <a href="/blog" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-400 transition-colors text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Blog
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
