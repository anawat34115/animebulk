# -------------------------------------------------------
# AnimeBulk Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# --- Email Provider (pick one) ---

# ConvertKit: Go to app.convertkit.com → Forms → your form → Settings → API
# The URL looks like: https://app.convertkit.com/forms/XXXXXXX/subscriptions
CONVERTKIT_FORM_URL=

# Mailchimp: Use your Mailchimp embedded form action URL
# The URL looks like: https://xxxxx.us1.list-manage.com/subscribe/post?u=XXXX&id=XXXX
# MAILCHIMP_URL=

# --- Site Config ---
# PUBLIC_SITE_URL=https://animebulk.com

# --- Keystatic GitHub OAuth ---
# Create a GitHub OAuth App at: https://github.com/settings/applications/new
# Homepage URL: https://animebulk.com
# Callback URL: https://animebulk.com/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
